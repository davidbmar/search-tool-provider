# search-tool-provider configuration
# Copy this file to .env and fill in the keys you need.
# Only the provider you choose needs a key — the rest can stay blank.

# Which provider to use: tavily | brave | serper | duckduckgo | google_cse | bing | fallback
SEARCH_PROVIDER=

# Tavily — https://tavily.com (1,000 free searches/month)
TAVILY_API_KEY=

# Brave Search — https://brave.com/search/api/ (2,000 free queries/month)
BRAVE_API_KEY=

# Serper (Google results) — https://serper.dev (2,500 free queries/month)
SERPER_API_KEY=

# Bing Web Search — https://portal.azure.com (1,000 free transactions/month)
BING_API_KEY=

# Google Custom Search — https://console.cloud.google.com/apis/credentials (100 free/day)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# Admin UI port (default: 8200)
# SEARCH_PROVIDER_ADMIN_PORT=8200
